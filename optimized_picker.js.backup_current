function strategyIndependentArithmetic(srcIdx, pool) {
  if (srcIdx < 1) return pool.slice(0, 5).map(e => e.number);
  const prevDraw = ALL_DRAWS[srcIdx - 1];
  const prev = [...prevDraw.front].sort((a, b) => a - b);
  const arithSet = new Set();
  for (let diff = 2; diff <= 6; diff++) {
    for (let j = 0; j < prev.length; j++) {
      for (let k = j + 1; k < prev.length; k++) {
        if (prev[k] - prev[j] === diff) {
          const left = prev[j] - diff;
          const right = prev[k] + diff;
          if (left >= 1 && left <= 35) arithSet.add(left);
          if (right >= 1 && right <= 35) arithSet.add(right);
          [left, right].forEach(ep => {
            if (ep >= 1 && ep <= 35) {
              if (ep - 1 >= 1) arithSet.add(ep - 1);
              if (ep + 1 <= 35) arithSet.add(ep + 1);
            }
          });
        }
      }
    }
  }
  const poolNums = pool.map(e => e.number);
  const scored = poolNums.map(n => {
    let s = 0;
    if (arithSet.has(n)) s += 20;
    for (const ep of arithSet) {
      const d = Math.abs(n - ep);
      if (d === 0) continue;
      if (d === 1) s += 5;
      if (d === 2) s += 2;
    }
    const entry = pool.find(e => e.number === n);
    if (entry) s += entry.score * 0.3;
    return { n, s };
  }).sort((a, b) => b.s - a.s);
  return scored.slice(0, 5).map(e => e.n).sort((a, b) => a - b);
}

// ===================== 热冷号混合组合生成 (v9.5: 组合评分+邻号冷号扩展) =====================
// 窗口: 选中行(srcIdx)~srcIdx+4 (目标期前6~10期的5期)
// 热号: 窗口内出现>=2次的号码, 按频率+前一期/选中行重号邻号评分
// 冷号: 窗口内0次出现 且 与选中行/前一期号码相邻(±1)或距离2-5的号码
// 生成5注: 每注=2热号+3冷号, 轮转选取保证多样性, 每注计算真实分数
function generateHotColdCombos(srcIdx, pool, hotCount = 2, coldCount = 3) {
  // 窗口5期频率统计
  const freq = new Array(36).fill(0);
  const windowNums = [];
  for (let i = srcIdx; i <= srcIdx + 4 && i < ALL_DRAWS.length; i++) {
    ALL_DRAWS[i].front.forEach(n => { freq[n]++; windowNums.push(n); });
  }

  const hotNums = [];   // >=2次
  const coldNums = [];  // 0次
  const warmNums = [];  // 1次(温号,用于冷号不足时补位)
  for (let n = 1; n <= 35; n++) {
    if (freq[n] >= 2) hotNums.push({ n, f: freq[n] });
    else if (freq[n] === 0) coldNums.push(n);
    else warmNums.push(n);
  }

  // 前一期(srcIdx-1)和选中行(srcIdx)的号码集合
  // 注意: srcIdx+9在升序数组中是未来数据(泄露!), 必须用srcIdx-1
  const prevDraw = (srcIdx - 1 >= 0) ? ALL_DRAWS[srcIdx - 1] : ALL_DRAWS[srcIdx];
  const prevSet = new Set(prevDraw.front);
  const srcSet = new Set(ALL_DRAWS[srcIdx].front);

  // 邻号集合: 选中行+前一期号码的±1
  const nbSet = new Set();
  ALL_DRAWS[srcIdx].front.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });
  prevDraw.front.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });

  // 冷号筛选: 只保留与邻号相邻的
  const coldFiltered = coldNums.filter(n => nbSet.has(n));

  // 🆕 v9.2: 桥接距离3-5且是选中行邻号的号码作为冷号候选（温号补位替代/补充）
  const bridgeNums = getBridgeNums(windowNums, ALL_DRAWS[srcIdx].front);
  const bridgeFiltered = bridgeNums.filter(n => nbSet.has(n));

  // 🆕 v9.1: 冷号不足时用温号(邻号)补位, 消除回退
  // 桥接号码用于补充冷号池，但不在基线测试中使用
  let coldWithWarm = [...coldFiltered, ...bridgeFiltered];
  if (coldWithWarm.length < coldCount) {
    const warmNb = warmNums.filter(n => nbSet.has(n));
    coldWithWarm = [...coldWithWarm, ...warmNb];
  }
  // 去重
  coldWithWarm = [...new Set(coldWithWarm)];

  if (hotNums.length < hotCount || coldWithWarm.length < coldCount) return null;

  // 🆕 v9.3: 将重号（前一期号码）加入热号候选池
  const repeatNums = prevDraw.front.filter(n => !hotNums.some(h => h.n === n));
  repeatNums.forEach(n => hotNums.push({ n, f: freq[n], isRepeat: true }));

  // 热号评分: 频率*10 + 前一期重号+15 + 前一期邻号+8 + 选中行重号+12
  const hotScored = hotNums.map(h => {
    let s = h.f * 10;
    if (prevSet.has(h.n)) s += 15;
    if (h.isRepeat) s += 30; // 🆕 v9.5: 重号额外加分提高到30
    const prevNb = new Set();
    prevDraw.front.forEach(n => { if (n > 1) prevNb.add(n - 1); if (n < 35) prevNb.add(n + 1); });
    if (prevNb.has(h.n)) s += 8;
    if (srcSet.has(h.n)) s += 12;
    return { n: h.n, s };
  }).sort((a, b) => b.s - a.s);

  // 冷号评分: 遗漏期数 + 前一期/选中行重号(概率低但保留)
  // 冷号优先(0分), 桥接号次之(-2分), 温号补位最后(-5分)
  const coldSet = new Set(coldFiltered);
  const bridgeSet = new Set(bridgeFiltered);
  const coldScored = coldWithWarm.map(n => {
    let s = coldSet.has(n) ? 0 : (bridgeSet.has(n) ? -2 : -5); // 冷号0 / 桥接-2 / 温号-5
    if (prevSet.has(n)) s += 15;
    if (srcSet.has(n)) s += 12;
    let gap = 0;
    for (let i = Math.max(0, srcIdx - 1); i >= Math.max(0, srcIdx - 10); i--) {
      if (ALL_DRAWS[i].front.includes(n)) break;
      gap++;
    }
    s += Math.min(gap, 10);
    return { n, s };
  }).sort((a, b) => b.s - a.s);

  const need = 5 - hotCount - coldCount; // 预测填充数(0表示全热冷)
  const combos = [];

  // 🆕 v9.5: 构建poolMap用于计算组合分数
  const poolMap = new Map(pool.map(p => [p.number, p.score]));

  for (let t = 0; t < 5; t++) {
    const used = new Set();
    const combo = [];

    // 热号轮转选取
    for (let j = 0; j < hotCount; j++) {
      const idx = (t * hotCount + j) % hotScored.length;
      if (!used.has(hotScored[idx].n)) { combo.push(hotScored[idx].n); used.add(hotScored[idx].n); }
    }
    for (const h of hotScored) { if (combo.length >= hotCount) break; if (!used.has(h.n)) { combo.push(h.n); used.add(h.n); } }

    // 冷号轮转选取
    for (let j = 0; j < coldCount; j++) {
      const idx = (t * coldCount + j) % coldScored.length;
      if (!used.has(coldScored[idx].n)) { combo.push(coldScored[idx].n); used.add(coldScored[idx].n); }
    }
    for (const c of coldScored) { if (combo.length >= hotCount + coldCount) break; if (!used.has(c.n)) { combo.push(c.n); used.add(c.n); } }

    // 预测填充(如果有剩余位置)
    if (need > 0) {
      const fill = pool.filter(e => !used.has(e.number)).sort((a, b) => b.score - a.score);
      for (let i = (t * need) % Math.max(fill.length, 1); combo.length < 5 && i < fill.length; i++) {
        if (!used.has(fill[i].number)) { combo.push(fill[i].number); used.add(fill[i].number); }
      }
      for (let i = 0; combo.length < 5 && i < fill.length; i++) {
        if (!used.has(fill[i].number)) { combo.push(fill[i].number); used.add(fill[i].number); }
      }
    }

    // 🆕 v9.5: 计算热冷号组合的真实分数(基于pool分数)
    if (combo.length === 5) {
      const comboScore = combo.reduce((sum, n) => sum + (poolMap.get(n) || 0), 0);
      combos.push({ numbers: combo.sort((a, b) => a - b), score: comboScore, source: 'hotCold' });
    }
  }

  return combos.length >= 5 ? combos : null;
}

// ═══ v13: 多样性贪心选择（最大化5注号码覆盖） ═══
// 策略: 第1注取最高分，后续每注选"新增号码最多+分数较高"的组合
function selectDiverseCombos(candidates, n) {
  if (candidates.length <= n) return candidates.slice();
  // 按分数排序
  const sorted = candidates.slice().sort((a, b) => b.score - a.score);
  const selected = [];
  const used = new Set();
  const taken = new Set();

  // 第1注: 取最高分
  selected.push(sorted[0]);
  sorted[0].numbers.forEach(n => used.add(n));
  taken.add(0);

  // 后续: 优先选新增号码最多的，同新增数时取分数高
  while (selected.length < n) {
    let bestIdx = -1, bestNew = -1, bestScore = -Infinity;
    for (let i = 0; i < sorted.length; i++) {
      if (taken.has(i)) continue;
      const newNums = sorted[i].numbers.filter(n => !used.has(n)).length;
      if (newNums > bestNew || (newNums === bestNew && sorted[i].score > bestScore)) {
        bestNew = newNums;
        bestScore = sorted[i].score;
        bestIdx = i;
      }
    }
    if (bestIdx === -1) break;
    selected.push(sorted[bestIdx]);
    sorted[bestIdx].numbers.forEach(n => used.add(n));
    taken.add(bestIdx);
  }

  return selected;
}

// ═══ v27: 随机生成+信号筛选（先随机后筛选） ═══
// 1. 从候选池大量随机生成5号组合
// 2. 每个组合用多重信号打分（重号/邻号/桥接/等差/多样性）
// 3. 每种信号选最优1注，保证策略间多样性
function generate5DifferentStrategyCombos(srcIdx, pool, comboRelationBonus) {
  const src0 = srcIdx;
  if (src0 < 0 || src0 >= ALL_DRAWS.length) return [];
  const sourceDraw = ALL_DRAWS[src0];
  if (!sourceDraw || !sourceDraw.front) return [];
  const srcNums = sourceDraw.front;
  if (!srcNums || srcNums.length < 2) return [];

  // ═══ 1. 信号数据 ═══
  const prevIdx = Math.max(0, src0 - 1);
  const prevDraw = ALL_DRAWS[prevIdx] || sourceDraw;
  const srcSet = new Set(srcNums);
  const prevSet = new Set(prevDraw.front);
  const nbSet = new Set();
  srcNums.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });
  prevDraw.front.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });
  // src桥接: src同一期中两个号码之间的"夹号"
  // 例: src有12和15, 桥接号=13,14; src有8和12, 桥接号=9,10,11
  const bridgeFreq = new Array(36).fill(0);
  for (let i = 0; i < srcNums.length; i++) {
    for (let j = i + 1; j < srcNums.length; j++) {
      const lo = Math.min(srcNums[i], srcNums[j]);
      const hi = Math.max(srcNums[i], srcNums[j]);
      const diff = hi - lo;
      if (diff >= 2 && diff <= 6) {
        for (let b = lo + 1; b < hi; b++) bridgeFreq[b]++;
      }
    }
  }

  // ═══ 窗口关系（双窗口: 近5期 + 间隔5-10期） ═══
  // 近窗口: src0-5 到 src0-1（覆盖面）
  const nearStart = Math.max(0, src0 - 5);
  const nearDraws = [];
  for (let i = nearStart; i < src0; i++) { if (ALL_DRAWS[i] && ALL_DRAWS[i].front) nearDraws.push(ALL_DRAWS[i].front); }
  // 远窗口: src0-9 到 src0-4（周期回补，间隔5-10期）
  const farStart = Math.max(0, src0 - 9);
  const farEnd = Math.max(0, src0 - 3);
  const farDraws = [];
  for (let i = farStart; i < farEnd; i++) { if (ALL_DRAWS[i] && ALL_DRAWS[i].front) farDraws.push(ALL_DRAWS[i].front); }
  // 合并窗口数据
  const wDraws = [...nearDraws, ...farDraws];
  const wFreq = new Array(36).fill(0);
  wDraws.forEach(d => d.forEach(n => wFreq[n]++));
  // gapDist: 号码距最近一次出现的间隔（从近窗口最近一期开始）
  const gapDist = new Array(36).fill(99);
  for (let g = 0; g < wDraws.length; g++) { const d = wDraws[wDraws.length - 1 - g]; for (const n of d) { if (gapDist[n] === 99) gapDist[n] = g; } }
  const coOccur = {};
  for (const d of wDraws) { for (let i = 0; i < d.length; i++) { for (let j = i + 1; j < d.length; j++) { const pk = d[i] < d[j] ? d[i] + '-' + d[j] : d[j] + '-' + d[i]; coOccur[pk] = (coOccur[pk] || 0) + 1; } } }
  const wNums = wDraws.flat();
  const arithFreq = new Array(36).fill(0);
  for (let diff = 2; diff <= 6; diff++) { for (let i = 0; i < wNums.length; i++) { for (let j = i + 1; j < wNums.length; j++) { if (wNums[j] - wNums[i] === diff) { if (wNums[i] - diff >= 1) arithFreq[wNums[i] - diff]++; if (wNums[j] + diff <= 35) arithFreq[wNums[j] + diff]++; } } } }

  const poolMap = new Map(pool.map(e => [e.number, e.score || 0]));

  // ═══ 窗口信号集合（用于交集分析） ═══
  const winRepSet = new Set();   // 窗口重号 1.08x
  const winBrSet = new Set();    // 窗口桥接: 窗口各期号码之间的"夹号"（同期+跨期）
  const winNbSet = new Set();    // 窗口邻号
  const prevNbSet = new Set();   // prev邻号
  for (let n = 1; n <= 35; n++) { if (wFreq[n] > 0) winRepSet.add(n); }
  // 窗口桥接: 窗口内任意两个号码（跨期或同期）之间的"夹号"
  // 例: 某期有12, 另一期有15 -> 桥接号=13,14
  const wUnique = [...new Set(wNums)];
  for (let i = 0; i < wUnique.length; i++) {
    for (let j = i + 1; j < wUnique.length; j++) {
      const lo = Math.min(wUnique[i], wUnique[j]);
      const hi = Math.max(wUnique[i], wUnique[j]);
      const diff = hi - lo;
      if (diff >= 2 && diff <= 6) {
        for (let b = lo + 1; b < hi; b++) winBrSet.add(b);
      }
    }
  }
  // 窗口桥接频率: 窗口号码间的"夹号"出现频次
  const winBridgeFreq = new Array(36).fill(0);
  for (let i = 0; i < wUnique.length; i++) {
    for (let j = i + 1; j < wUnique.length; j++) {
      const lo = Math.min(wUnique[i], wUnique[j]);
      const hi = Math.max(wUnique[i], wUnique[j]);
      const diff = hi - lo;
      if (diff >= 2 && diff <= 6) {
        for (let b = lo + 1; b < hi; b++) winBridgeFreq[b]++;
      }
    }
  }
  // 窗口邻号: 窗口号码的±1
  wNums.forEach(w => {
    if (w - 1 >= 1) winNbSet.add(w - 1);
    if (w + 1 <= 35) winNbSet.add(w + 1);
  });
  prevDraw.front.forEach(p => { if (p - 1 >= 1) prevNbSet.add(p - 1); if (p + 1 <= 35) prevNbSet.add(p + 1); });

  // 远窗口≤1号码信号（分析: 远窗口出现0或1次的号码命中率更高15.61%）
  const farFreq = new Array(36).fill(0);
  for (const d of farDraws) { d.forEach(n => farFreq[n]++); }
  const farLeq1Set = new Set();
  for (let n = 1; n <= 35; n++) { if (farFreq[n] <= 1) farLeq1Set.add(n); }

  // ═══ 2. 5组不同锚点配置 ═══
  const srcAnchors = [...srcSet];
  const prevAnchorsAll = [...prevSet].filter(n => !srcSet.has(n));
  const nbAnchors = [...nbSet].filter(n => !srcSet.has(n) && !prevSet.has(n));
  const brAnchors = [];
  for (let n = 1; n <= 35; n++) { if (bridgeFreq[n] > 0 && !srcSet.has(n) && !prevSet.has(n) && !nbSet.has(n)) brAnchors.push(n); }
  const allAnchors = [...new Set([...srcAnchors, ...prevAnchorsAll, ...nbAnchors])];
  const anchorSet = new Set(allAnchors);

  // ═══ 2.5 动态窗口关系补全（按历史命中率校准） ═══
  function fillByWindowRelation(combo, used, rng, weights) {
    while (combo.length < 5) {
      const candidates = [];
      for (let n = 1; n <= 35; n++) {
        if (used.has(n)) continue;
        let s = 0;

        // ① 共现关系
        let coSum = 0;
        for (const cc of combo) {
          const pk = n < cc ? n + '-' + cc : cc + '-' + n;
          if (coOccur[pk]) coSum += coOccur[pk];
        }
        s += coSum * weights.co;

        // ② 邻接关系
        let adjSum = 0;
        for (const cc of combo) { if (Math.abs(n - cc) === 1) adjSum++; }
        s += adjSum * weights.adj;

        // ③ 等差延伸
        let arSum = 0;
        for (let i = 0; i < combo.length; i++) {
          for (let j = i + 1; j < combo.length; j++) {
            const diff = combo[j] - combo[i];
            if (combo[i] - diff === n || combo[j] + diff === n) arSum++;
          }
        }
        s += arSum * weights.ar;

        // ④ 遗漏回补（双窗口: gap 0-4近窗口, 5-10远窗口）
        let gapScore = 0;
        const gap = gapDist[n];
        if (gap >= 2 && gap <= 4) gapScore = 10;       // 近窗口回补
        else if (gap === 1) gapScore = 5;               // 近窗口续出
        else if (gap >= 5 && gap <= 8) gapScore = 8;    // 远窗口回补
        else if (gap === 99 && wFreq[n] === 0) gapScore = -2;
        s += gapScore * weights.gap;

        // ⑤ 窗口频率
        s += wFreq[n] * weights.freq;

        // ⑥ 桥接（src桥接 + 窗口桥接）
        s += bridgeFreq[n] * weights.br;
        s += winBridgeFreq[n] * weights.br * 0.4;

        // ⑦ pool + 关系加分
        s += (poolMap.get(n) || 0) * 0.3 * weights.pool;
        s += ((comboRelationBonus && comboRelationBonus.get(n)) || 0) * weights.bonus;

        // ⑦b 信号计数优化（3重最优1.16x, 5+惩罚0.64x）
        let nSig = (srcSet.has(n)?1:0) + (nbSet.has(n)?1:0) + (srcBridgeG24.has(n)?1:0) + (srcArithD3.has(n)?1:0) + (prevSet.has(n)?1:0) + (winRepSet.has(n)?1:0);
        if (nSig === 3) s += 4;
        if (nSig >= 5) s -= 3;

        // ⑦c 远窗口≤1信号
        if (farLeq1Set.has(n)) s += 4;

        // ⑧ 随机扰动
        s += rng() * weights.noise;

        candidates.push({ n, s });
      }

      candidates.sort((a, b) => b.s - a.s);
      const pool = rng() < 0.6 ? candidates.slice(0, 8) : candidates.slice(0, 20);
      const totalW = pool.reduce((sum, c) => sum + Math.max(1, c.s), 0);
      let r = rng() * totalW;
      let picked = pool[0].n;
      for (const c of pool) {
        r -= Math.max(1, c.s);
        if (r <= 0) { picked = c.n; break; }
      }
      combo.push(picked);
      used.add(picked);
    }
  }

  // PRNG
  let _seed = (src0 * 1000 + 42) >>> 0;
  function rng() { _seed = (_seed * 1664525 + 1013904223) >>> 0; return (_seed >>> 16) / 65536; }

  // 5组: 4组src(2-3锚定) + 1组混合(50%src/50%非src随机切换)
  const defaultW = { co: 10, adj: 8, ar: 12, gap: 10, freq: 4, br: 3, pool: 1, bonus: 1, noise: 16 };
  const poolTopNonAnchor = [...pool].sort((a, b) => b.score - a.score)
    .map(e => e.number).filter(n => !srcSet.has(n) && !prevSet.has(n)).slice(0, 12);
  const coldRecovery = [];
  for (let n = 1; n <= 35; n++) {
    if (gapDist[n] >= 3 && gapDist[n] <= 8) coldRecovery.push(n);
  }
  const nonSrcAnchors = poolTopNonAnchor.concat(coldRecovery);
  const nonSrcW = { co: 12, adj: 8, ar: 10, gap: 15, freq: 6, br: 4, pool: 2, bonus: 1, noise: 16 };

  // 预计算src等差d2/d3号集（组定义前需要）
  const srcArithD2 = new Set();
  const srcArithD3 = new Set();
  for (let i = 0; i < srcNums.length; i++) {
    for (let j = i + 1; j < srcNums.length; j++) {
      const diff = srcNums[j] - srcNums[i];
      if (diff === 2) {
        if (srcNums[i] - 2 >= 1) srcArithD2.add(srcNums[i] - 2);
        if (srcNums[j] + 2 <= 35) srcArithD2.add(srcNums[j] + 2);
      }
      if (diff === 3) {
        if (srcNums[i] - 3 >= 1) srcArithD3.add(srcNums[i] - 3);
        if (srcNums[j] + 3 <= 35) srcArithD3.add(srcNums[j] + 3);
      }
    }
  }
  // src桥接号集: src同一期中两个号码之间的"夹号"
  // 例: src有8和12, 桥接号=9,10,11; src有12和15, 桥接号=13,14
  const srcBridgeG24 = new Set();
  for (let i = 0; i < srcNums.length; i++) {
    for (let j = i + 1; j < srcNums.length; j++) {
      const lo = Math.min(srcNums[i], srcNums[j]);
      const hi = Math.max(srcNums[i], srcNums[j]);
      const diff = hi - lo;
      if (diff >= 2 && diff <= 6) {
        for (let b = lo + 1; b < hi; b++) srcBridgeG24.add(b);
      }
    }
  }

  // ═══════════════════════════════════════════════════════
  // Phase 1: 信号筛选 - 用交集信号给池中号码打分，筛选出最强信号子集
  // ═══════════════════════════════════════════════════════
  function signalFilterPool(pool, srcSet, nbSet, prevSet, srcBridgeG24, srcArithD3, winRepSet, winBrSet) {
    // 每个号码的信号命中次数
    const sigScore = new Map();
    for (const e of pool) {
      const n = e.number;
      let s = 0;
      // 单信号加分（基于历史命中率）
      if (srcSet.has(n)) s += 3;       // src重号 0.92x 弱正
      if (nbSet.has(n)) s += 3;        // src邻号 0.93x 弱正
      if (prevSet.has(n)) s += 5;      // prev重号 1.14x 正信号
      if (srcBridgeG24.has(n)) s += 2; // src桥接 0.85x 极弱
      if (srcArithD3.has(n)) s += 2;   // src等差d3
      if (winRepSet.has(n)) s += 3;    // 窗口重号 1.08x 弱正
      if (winBrSet.has(n)) s += 1;     // 窗口桥接

      // 交集信号加分（最强信号）
      const inSrcBr = srcBridgeG24.has(n);
      const inSrcNb = nbSet.has(n);
      const inPrev = prevSet.has(n);
      const inWinRep = winRepSet.has(n);
      const inArD3 = srcArithD3.has(n);
      const inWinBr = winBrSet.has(n);
      // 二重交集
      if (inSrcBr && inPrev) s += 15;   // src桥接∩prev重号 5.78x
      if (inSrcNb && inPrev) s += 12;   // src邻号∩prev重号 4.08x
      if (inSrcNb && inWinRep) s += 10; // src邻号∩窗口重号 3.85x
      if (inArD3 && inWinBr) s += 8;    // src等差d3∩窗口桥接 3.63x
      // 三重交集（更强）
      if (inSrcBr && inPrev && inWinRep) s += 20;
      if (inSrcNb && inPrev && inWinRep) s += 18;

      sigScore.set(n, s);
    }
    // 按信号分排序，筛选前N个（保留至少8个，最多全池）
    const sorted = [...pool].sort((a, b) => {
      const sa = sigScore.get(a.number) || 0;
      const sb = sigScore.get(b.number) || 0;
      return sb - sa;
    });
    // 动态阈值：信号分>=3的全部保留，否则至少保留10个（放宽筛选）
    const minKeep = 10;
    const threshold = 3;
    const filtered = [];
    for (const e of sorted) {
      const s = sigScore.get(e.number) || 0;
      if (s >= threshold || filtered.length < minKeep) {
        filtered.push({ ...e, signalScore: s });
      }
    }
    return filtered;
  }

  // 执行信号筛选
  const filteredPool = signalFilterPool(pool, srcSet, nbSet, prevSet, srcBridgeG24, srcArithD3, winRepSet, winBrSet);
  const filteredNums = new Set(filteredPool.map(e => e.number));

  // ═══════════════════════════════════════════════════════
  // Phase 2: 5组不同策略（混合模式：信号筛选+全池多样性）
  // ═══════════════════════════════════════════════════════
  // 策略1-3: 用信号筛选池（保证信号质量）
  // 策略4-5: 用全池（恢复多样性，避免过度筛选）
  const srcBrAnchors = [...srcBridgeG24].filter(n => filteredNums.has(n));
  const winRepAnchors = [];
  for (let n = 1; n <= 35; n++) { if (winRepSet.has(n) && filteredNums.has(n)) winRepAnchors.push(n); }
  const srcNbAnchors = [...nbSet].filter(n => !srcSet.has(n) && !prevSet.has(n) && filteredNums.has(n));
  const prevAnchors = [...prevSet].filter(n => filteredNums.has(n));
  // 全池多样性锚点（不经过信号筛选）
  const allPoolNums = pool.map(e => e.number);

  const groups = [
    // 第1组: src桥接∩prev重号 (5.78x最强) - 信号筛选池
    { anchors: srcBrAnchors.concat(prevAnchors), count: [2, 3], w: defaultW },
    // 第2组: src邻号∩prev重号 (4.08x) - 信号筛选池
    { anchors: srcNbAnchors.concat(prevAnchors), count: [2, 3], w: defaultW },
    // 第3组: src邻号∩窗口重号 (3.85x) - 信号筛选池
    { anchors: srcNbAnchors.concat(winRepAnchors), count: [2, 3], w: defaultW },
    // 第4组: 全池频率Top5（提升去重率）
    { diversityMode: 'allPoolFreqTop5' },
    // 第5组: 全池频率次Top5（避免与第4组重复）
    { diversityMode: 'allPoolFreqNext5' },
  ];

  function scoreCombo(combo) {
    let score = 0, srcHit = 0;
    // 号码级：弱信号屏蔽（0.85-0.93x低于基线的不加分，仅保留信号标记用于交集）
    for (const n of combo) {
      // src重号 0.92x低于基线！从+20降到+8
      if (srcSet.has(n)) { score += 8; srcHit++; }
      // prev重号 1.14x正信号，保持
      if (prevSet.has(n)) score += 10;
      // src邻号 0.93x低于基线，从+12降到+5
      if (nbSet.has(n)) score += 5;
      // 桥接 0.85x，从×6降到×3
      score += bridgeFreq[n] * 3;
      score += winBridgeFreq[n] * 2;
      // 等差延伸
      score += arithFreq[n] * 5;
      // 窗口频率 1.08x弱正信号
      const wf = wFreq[n];
      if (wf > 0) score += wf * 3;
      // 遗漏回补
      const gap = gapDist[n];
      if (gap >= 2 && gap <= 4) score += 6;
      else if (gap === 1) score += 3;
      else if (gap >= 5 && gap <= 8) score += 5;
      else if (gap === 99 && wf === 0) score -= 3;
      // pool分数
      score += (poolMap.get(n) || 0) * 0.3;
      score += (comboRelationBonus && comboRelationBonus.get(n)) || 0;
    }
    // 窗口共现
    for (let i = 0; i < combo.length; i++) {
      for (let j = i + 1; j < combo.length; j++) {
        const pk = combo[i] < combo[j] ? combo[i] + '-' + combo[j] : combo[j] + '-' + combo[i];
        if (coOccur[pk]) score += coOccur[pk] * 3;
      }
    }

    // 组合内交集对加分（强信号，这是核心区分力）
    let strongPairs = 0;
    for (let i = 0; i < combo.length; i++) {
      for (let j = i + 1; j < combo.length; j++) {
        const a = combo[i], b = combo[j];
        const aBr = srcBridgeG24.has(a) || srcBridgeG24.has(b);
        const bPr = prevSet.has(a) || prevSet.has(b);
        const aNb = nbSet.has(a) || nbSet.has(b);
        const bWr = winRepSet.has(a) || winRepSet.has(b);
        const aD3 = srcArithD3.has(a) || srcArithD3.has(b);
        const bWbr = winBrSet.has(a) || winBrSet.has(b);
        if (aBr && bPr) { score += 25; strongPairs++; }
        if (aNb && bPr) { score += 18; strongPairs++; }
        if (aNb && bWr) { score += 15; strongPairs++; }
        if (aD3 && bWbr) { score += 12; strongPairs++; }
      }
    }
    if (strongPairs >= 2) score = Math.floor(score * 1.3);

    // src多命中（弱奖励，src单信号弱但多命中仍有一定爆发力）
    if (srcHit >= 2) score += 10;
    if (srcHit >= 3) score += 5;

    // 3重信号奖励
    for (const n of combo) {
      let nSig = (srcSet.has(n)?1:0) + (nbSet.has(n)?1:0) + (srcBridgeG24.has(n)?1:0) + (srcArithD3.has(n)?1:0) + (prevSet.has(n)?1:0) + (winRepSet.has(n)?1:0);
      if (nSig === 3) score += 3;
      if (nSig >= 5) score -= 4;
    }

    return score;
  }

  // 屏蔽版评分：弱信号0分，纯靠强交集+窗口关系区分（第5组专用）
  function scoreComboShielded(combo) {
    let score = 0, srcHit = 0;
    for (const n of combo) {
      if (srcSet.has(n)) srcHit++;                    // src重号 0.92x 屏蔽
      if (prevSet.has(n)) score += 10;                // prev重号 1.14x 保留
      // src邻号/桥接 屏蔽
      score += winBridgeFreq[n] * 2;
      score += arithFreq[n] * 3;
      const wf = wFreq[n];
      if (wf > 0) score += wf * 2;
      // 远窗口≤1信号
      if (farLeq1Set.has(n)) score += 4;
      const gap = gapDist[n];
      if (gap >= 2 && gap <= 4) score += 4;
      else if (gap >= 5 && gap <= 8) score += 3;
      else if (gap === 99 && wf === 0) score -= 3;
      score += (poolMap.get(n) || 0) * 0.3;
      score += (comboRelationBonus && comboRelationBonus.get(n)) || 0;
    }
    for (let i = 0; i < combo.length; i++) {
      for (let j = i + 1; j < combo.length; j++) {
        const pk = combo[i] < combo[j] ? combo[i] + '-' + combo[j] : combo[j] + '-' + combo[i];
        if (coOccur[pk]) score += coOccur[pk] * 3;
      }
    }
    // 强交集（同scoreCombo）
    let strongPairs = 0;
    for (let i = 0; i < combo.length; i++) {
      for (let j = i + 1; j < combo.length; j++) {
        const a = combo[i], b = combo[j];
        const aBr = srcBridgeG24.has(a) || srcBridgeG24.has(b);
        const bPr = prevSet.has(a) || prevSet.has(b);
        const aNb = nbSet.has(a) || nbSet.has(b);
        const bWr = winRepSet.has(a) || winRepSet.has(b);
        const aD3 = srcArithD3.has(a) || srcArithD3.has(b);
        const bWbr = winBrSet.has(a) || winBrSet.has(b);
        if (aBr && bPr) { score += 25; strongPairs++; }
        if (aNb && bPr) { score += 18; strongPairs++; }
        if (aNb && bWr) { score += 15; strongPairs++; }
        if (aD3 && bWbr) { score += 12; strongPairs++; }
      }
    }
    if (strongPairs >= 2) score = Math.floor(score * 1.3);
    if (srcHit >= 2) score += 6;
    if (srcHit >= 3) score += 3;
    for (const n of combo) {
      let nSig = (srcSet.has(n)?1:0) + (nbSet.has(n)?1:0) + (srcBridgeG24.has(n)?1:0) + (srcArithD3.has(n)?1:0) + (prevSet.has(n)?1:0) + (winRepSet.has(n)?1:0);
      if (nSig === 3) score += 3;
      if (nSig >= 5) score -= 4;
    }
    return score;
  }

  // ═══ 3. 每组生成组合，选最高分 ═══
  const selected = [];
  const usedKeys = new Set();

  // 计算窗口期号码频率（用于智能多样性策略4-5）
  const windowStart = Math.max(0, srcIdx - 4);
  const windowNumbers = [];
  for (let i = windowStart; i < srcIdx; i++) {
    if (ALL_DRAWS[i] && ALL_DRAWS[i].front) {
      windowNumbers.push(...ALL_DRAWS[i].front);
    }
  }
  const windowFreq = new Map();
  windowNumbers.forEach(n => {
    windowFreq.set(n, (windowFreq.get(n) || 0) + 1);
  });
  // 全池频率排序（用于策略4-5多样性）
  const allPoolFreqNums = Array.from(windowFreq.entries())
    .sort((a, b) => b[1] - a[1] || a[0] - b[0])
    .map(([num]) => num);
  // 候选池按评分排序（原始池）
  const poolSorted = [...pool].sort((a, b) => b.score - a.score);
  const poolNums = poolSorted.map(e => e.number);
  // 信号筛选池按评分排序
  const filteredPoolSorted = [...filteredPool].sort((a, b) => b.score - a.score);
  const filteredPoolNums = filteredPoolSorted.map(e => e.number);
  // 窗口频率排序（信号筛选池内的频率>0的降序，无频率的按评分）
  const filteredFreqNums = Array.from(windowFreq.entries())
    .sort((a, b) => b[1] - a[1] || a[0] - b[0])
    .map(([num]) => num)
    .filter(n => filteredNums.has(n));
  const filteredNoFreqNums = filteredPoolNums.filter(n => !windowFreq.has(n));
  const filteredFreqSorted = [...filteredFreqNums, ...filteredNoFreqNums];

  for (const grp of groups) {
    if (selected.length >= 5) break;

    // 全池多样性策略（策略4-5）
    if (grp.diversityMode) {
      const combo4Set = grp.diversityMode === 'allPoolFreqNext5' && selected[3] ? new Set(selected[3].numbers) : new Set();
      // 已选号码集合（避免重复）
      const allSelectedNums = new Set();
      for (const sel of selected) {
        for (const n of sel.numbers) allSelectedNums.add(n);
      }
      // 从全池中选取不重复的高频号码
      let combo = [];
      if (grp.diversityMode === 'allPoolFreqTop5') {
        // 策略4: 全池频率排序Top5
        for (const n of allPoolFreqNums) {
          if (combo.length >= 5) break;
          if (!allSelectedNums.has(n)) combo.push(n);
        }
      } else {
        // 策略5: 全池频率排序次Top5（避开策略4的号码）
        for (const n of allPoolFreqNums) {
          if (combo.length >= 5) break;
          if (!allSelectedNums.has(n) && !combo4Set.has(n)) combo.push(n);
        }
        // 不足则从全池评分高分补
        if (combo.length < 5) {
          for (const n of poolNums) {
            if (combo.length >= 5) break;
            if (!combo.includes(n) && !combo4Set.has(n) && !allSelectedNums.has(n)) combo.push(n);
          }
        }
      }
      if (combo.length >= 5) {
        combo = combo.slice(0, 5).sort((a, b) => a - b);
        const key = JSON.stringify(combo);
        if (!usedKeys.has(key)) {
          usedKeys.add(key);
          selected.push({ numbers: combo, source: '全池多样性' });
        }
      }
      continue;
    }

    // 原有信号筛选逻辑
    let bestCombo = null;
    let bestScore = -Infinity;
    const seen = new Set();

    for (let iter = 0; iter < 600; iter++) {
      const combo = [];
      const used = new Set();
      const ac = grp.count[0] + Math.floor(rng() * (grp.count[1] - grp.count[0] + 1));
      const shuffled = [...grp.anchors].sort(() => rng() - 0.5);
      for (let i = 0; i < Math.min(ac, shuffled.length) && combo.length < 5; i++) { const n = shuffled[i]; if (!used.has(n)) { combo.push(n); used.add(n); } }
      // 动态窗口关系补全
      fillByWindowRelation(combo, used, rng, grp.w);
      combo.sort((a, b) => a - b);
      const key = JSON.stringify(combo);
      if (seen.has(key)) continue;
      seen.add(key);
      if (usedKeys.has(key)) continue;
      const sc = scoreCombo(combo);
      if (sc > bestScore) { bestScore = sc; bestCombo = combo; }
    }

    if (bestCombo) {
      const key = JSON.stringify(bestCombo);
      usedKeys.add(key);
      selected.push({ numbers: bestCombo, source: '信号筛选+锚定策略' });
    }
  }

  // 补充不足5注: 从信号筛选池生成更多组合
  while (selected.length < 5) {
    let bestCombo = null;
    let bestScore = -Infinity;
    for (let iter = 0; iter < 600; iter++) {
      const combo = [];
      const used = new Set();
      const ac = 2 + Math.floor(rng() * 2);
      // 从筛选池中随机选取锚点
      const shuffled = [...filteredPoolNums].sort(() => rng() - 0.5);
      for (let i = 0; i < Math.min(ac, shuffled.length) && combo.length < 5; i++) { const n = shuffled[i]; if (!used.has(n)) { combo.push(n); used.add(n); } }
      fillByWindowRelation(combo, used, rng, defaultW);
      combo.sort((a, b) => a - b);
      const key = JSON.stringify(combo);
      if (usedKeys.has(key)) continue;
      const sc = scoreCombo(combo);
      if (sc > bestScore) { bestScore = sc; bestCombo = combo; }
    }
    if (bestCombo) { usedKeys.add(JSON.stringify(bestCombo)); selected.push({ numbers: bestCombo, source: '信号筛选池补充' }); }
    else break;
  }

  return selected.slice(0, 5);
}

// 辅助函数：计算等差关系
function getArithmeticRelations(windowNumbers) {
  const extensionNumbers = new Map();
  
  for (let diff = 2; diff <= 6; diff++) {
    for (let i = 0; i < windowNumbers.length; i++) {
      for (let j = i + 1; j < windowNumbers.length; j++) {
        if (windowNumbers[j] - windowNumbers[i] === diff) {
          const left = windowNumbers[i] - diff;
          const right = windowNumbers[j] + diff;
          
          [left, right].forEach(endpoint => {
            if (endpoint >= 1 && endpoint <= 35) {
              const cur = extensionNumbers.get(endpoint) || { score: 0 };
              cur.score += 10;
              extensionNumbers.set(endpoint, cur);
            }
          });
          
          [left, right].forEach(endpoint => {
            if (endpoint >= 1 && endpoint <= 35) {
              [endpoint - 1, endpoint + 1].forEach(adj => {
                if (adj >= 1 && adj <= 35) {
                  const cur = extensionNumbers.get(adj) || { score: 0 };
                  cur.score += 5;
                  extensionNumbers.set(adj, cur);
                }
              });
            }
          });
        }
      }
    }
  }
  
  return extensionNumbers;
}

// 辅助函数：计算相邻关系
function getAdjacentRelations(windowNumbers) {
  const adjacentNumbers = new Map();
  
  windowNumbers.forEach(n => {
    [n - 1, n + 1].forEach(adj => {
      if (adj >= 1 && adj <= 35) {
        const cur = adjacentNumbers.get(adj) || { score: 0 };
        cur.score += 8;
        adjacentNumbers.set(adj, cur);
      }
    });
  });
  
  return adjacentNumbers;
}

// 辅助函数：计算桥接关系
function getBridgeRelations(windowNumbers) {
  const bridgeNumbers = new Map();
  
  for (let i = 0; i < windowNumbers.length; i++) {
    for (let j = i + 1; j < windowNumbers.length; j++) {
      const dist = Math.abs(windowNumbers[j] - windowNumbers[i]);
      if (dist >= 3 && dist <= 5) {
        const mid = Math.round((windowNumbers[i] + windowNumbers[j]) / 2);
        if (mid >= 1 && mid <= 35 && mid !== windowNumbers[i] && mid !== windowNumbers[j]) {
          const cur = bridgeNumbers.get(mid) || { score: 0 };
          cur.score += 6;
          bridgeNumbers.set(mid, cur);
        }
      }
    }
  }
  
  return bridgeNumbers;
}

// 辅助函数：计算重复关系
function getRepeatRelations(windowNumbers) {
  const repeatNumbers = new Map();
  
  windowNumbers.forEach(n => {
    const cur = repeatNumbers.get(n) || { score: 0 };
    cur.score += 12;
    repeatNumbers.set(n, cur);
  });
  
  return repeatNumbers;
}

// ═══ v23: src为主+窗口信号comboRelationBonus ═══
// 关键发现：src关系全部>基线(15.0-15.6%)，prev关系全部<基线(13.1-13.7%)
// 最强交集是src内部交集（src重号∩src桥接=19.2%, src等差d3∩src桥接=20.0%）
// v20错误: prev重号∩prev邻号给10分但实际仅15.5%(接近随机)
//
// v23权重设计（按实际命中率）：
// - src等差d3∩src桥接g2-4: 15分 (20.0%, 1.40x) ← 最强！
// - src重号∩src桥接g2-4:   12分 (19.2%, 1.35x)
// - src邻号∩prev重号:       10分 (19.3%, 1.35x) 212样本可靠
// - src等差d2∩prev重号:     14分 (23.8%, 1.67x) 但仅21样本，谨慎给分
// - src重号:                 8分 (15.6%, 1.09x) ← 单信号最强
// - src等差d2:               7分 (15.5%, 1.09x)
// - src邻号:                 6分 (15.3%, 1.07x)
// - src桥接g2-4:             5分 (15.0%, 1.05x)
// - prev重号∩prev邻号:       1分 (15.5%, 1.08x) ← 降为最低
// - prev单关系:              0分 (13.1-13.7%) ← 不加分
// - 窗口信号（低权重，因为接近基线）：
//   - 窗口重号:              2分 (14.8%, 1.04x)
//   - 窗口桥接:              2分 (14.7%, 1.03x)
//   - 窗口邻号:              1分 (14.3%, 1.00x) 接近基线
function computeComboRelationBonus(sourceDraw, frontRefDraw, srcIdx) {
  const bonusMap = new Map();
  if (!sourceDraw) return bonusMap;

  const srcNums = sourceDraw.front;
  if (!srcNums || srcNums.length < 2) return bonusMap;

  // src关系集合
  const srcRep = new Set(srcNums);                        // src重号
  const srcNb = new Set();                                // src邻号(±1)
  srcNums.forEach(n => { if (n > 1) srcNb.add(n - 1); if (n < 35) srcNb.add(n + 1); });

  // src等差d2延伸点
  const srcArithD2 = new Set();
  const sSorted = [...srcNums].sort((a, b) => a - b);
  for (let i = 0; i < sSorted.length; i++) {
    for (let j = i + 1; j < sSorted.length; j++) {
      const d = sSorted[j] - sSorted[i];
      if (d === 2) {
        if (sSorted[i] - 2 >= 1) srcArithD2.add(sSorted[i] - 2);
        if (sSorted[j] + 2 <= 35) srcArithD2.add(sSorted[j] + 2);
      }
    }
  }

  // src等差d3延伸点（最强信号源）
  const srcArithD3 = new Set();
  for (let i = 0; i < sSorted.length; i++) {
    for (let j = i + 1; j < sSorted.length; j++) {
      const d = sSorted[j] - sSorted[i];
      if (d === 3) {
        if (sSorted[i] - 3 >= 1) srcArithD3.add(sSorted[i] - 3);
        if (sSorted[j] + 3 <= 35) srcArithD3.add(sSorted[j] + 3);
      }
    }
  }

  // src桥接g2-4: src号码间距2-4的中点
  const srcBridge = new Set();
  for (let i = 0; i < sSorted.length; i++) {
    for (let j = i + 1; j < sSorted.length; j++) {
      const dist = sSorted[j] - sSorted[i];
      if (dist >= 2 && dist <= 4) {
        for (let mid = sSorted[i] + 1; mid < sSorted[j]; mid++) {
          srcBridge.add(mid);
        }
      }
    }
  }

  // 前一期关系集合（权重低）
  let prevRep = new Set(), prevNb = new Set();
  if (frontRefDraw) {
    const prevNums = frontRefDraw.front;
    prevRep = new Set(prevNums);
    prevNums.forEach(n => { if (n > 1) prevNb.add(n - 1); if (n < 35) prevNb.add(n + 1); });
  }

  // 窗口信号（前5期）
  const windowStart = Math.max(0, srcIdx - 4);
  const windowNumbers = [];
  for (let i = windowStart; i < srcIdx; i++) {
    if (ALL_DRAWS[i] && ALL_DRAWS[i].front) {
      windowNumbers.push(...ALL_DRAWS[i].front);
    }
  }
  const uniqueWindow = [...new Set(windowNumbers)];
  
  // 窗口重号（窗口内出现>=2次的号码）
  const windowRep = new Set();
  const windowCount = new Map();
  windowNumbers.forEach(n => {
    windowCount.set(n, (windowCount.get(n) || 0) + 1);
    if (windowCount.get(n) >= 2) windowRep.add(n);
  });
  
  // 窗口桥接（窗口内号码间距3-5的中点）
  const windowBridge = new Set();
  for (let i = 0; i < uniqueWindow.length; i++) {
    for (let j = i + 1; j < uniqueWindow.length; j++) {
      const dist = Math.abs(uniqueWindow[j] - uniqueWindow[i]);
      if (dist >= 3 && dist <= 5) {
        const mid = Math.round((uniqueWindow[i] + uniqueWindow[j]) / 2);
        if (mid >= 1 && mid <= 35 && mid !== uniqueWindow[i] && mid !== uniqueWindow[j]) {
          windowBridge.add(mid);
        }
      }
    }
  }
  
  // 窗口邻号
  const windowNb = new Set();
  uniqueWindow.forEach(n => {
    if (n > 1) windowNb.add(n - 1);
    if (n < 35) windowNb.add(n + 1);
  });

  for (let n = 1; n <= 35; n++) {
    const a3 = srcArithD3.has(n);  // src等差d3
    const a2 = srcArithD2.has(n);  // src等差d2
    const b = srcNb.has(n);        // src邻号
    const e = srcRep.has(n);       // src重号
    const g = srcBridge.has(n);    // src桥接g2-4
    const c = prevRep.has(n);      // prev重号
    const d = prevNb.has(n);       // prev邻号
    const wRep = windowRep.has(n); // 窗口重号
    const wBr = windowBridge.has(n); // 窗口桥接
    const wNb = windowNb.has(n);   // 窗口邻号

    // 计算src信号（用于判断src∩窗口组合）
    const hasSrc = e || a2 || b || g || a3;

    let score = 0;

    // ═══ src内部交集（最强信号） ═══
    if (a3 && g) score = 15;       // src等差d3∩src桥接 = 20.0% (1.40x)
    else if (a2 && c) score = 14;       // src等差d2∩prev重号 = 23.8% (1.67x)
    else if (e && g) score = 12;        // src重号∩src桥接 = 19.2% (1.35x)

    // ═══ src + prev交集 ═══
    else if (b && c) score = 10;        // src邻号∩prev重号 = 19.3% (1.35x)

    // ═══ 窗口信号（低权重，v23） ═══
    else if (hasSrc && wRep) score = 3; // src + 窗口重号（低权重辅助）— 测试纯v21时禁用

    // ═══ src单关系（全部>基线14.3%） ═══
    else if (e) score = 8;              // src重号 = 15.6% (1.09x)
    else if (a2) score = 7;             // src等差d2 = 15.5% (1.09x)
    else if (b) score = 6;              // src邻号 = 15.3% (1.07x)
    else if (g) score = 5;              // src桥接g2-4 = 15.0% (1.05x)

    // ═══ prev弱信号 ═══
    else if (c && d) score = 1;         // prev重号∩prev邻号 = 15.5% (1.08x)

    // 窗口邻号/桥接不单独给分（覆盖太广：77%/66%，会稀释信号）

    if (score > 0) bonusMap.set(n, score);
  }

  return bonusMap;
}

// ═══ v10: 策略多样性 - 重号偏重 ═══
// 策略: 选中行号码占主导(4个) + 前一期号码(1个) + 桥接补全
// v26: 组合变体生成，变化src/prev/pool比例，产生真正不同的候选
function generateRepeatCombos(srcIdx, pool) {
  const src0 = srcIdx;
  if (src0 < 0 || src0 >= ALL_DRAWS.length) return null;
  const srcDraw = ALL_DRAWS[src0];
  if (!srcDraw) return null;
  const prevIdx = Math.max(0, src0 - 1);
  const prevDraw = ALL_DRAWS[prevIdx] || srcDraw;
  
  const srcSet = new Set(srcDraw.front);
  const prevSet = new Set(prevDraw.front);
  const prevNb = new Set();
  prevDraw.front.forEach(n => { if (n > 1) prevNb.add(n - 1); if (n < 35) prevNb.add(n + 1); });
  
  const poolMap = new Map(pool.map(e => [e.number, e.score || 0]));
  const scored = [];
  for (let n = 1; n <= 35; n++) {
    let s = 0;
    if (srcSet.has(n)) s += 15;
    if (prevSet.has(n)) s += 12;
    if (prevNb.has(n)) s += 8;
    if (s > 0) scored.push({ n, s: s + (poolMap.get(n) || 0) * 0.5 });
  }
  scored.sort((a, b) => b.s - a.s);
  
  // 分类号码
  const srcNums = scored.filter(s => srcSet.has(s.n)).map(s => s.n);
  const prevNums = scored.filter(s => !srcSet.has(s.n) && prevSet.has(s.n)).map(s => s.n);
  const poolTop = [...pool].sort((a, b) => b.score - a.score).map(e => e.number).filter(n => !srcSet.has(n) && !prevSet.has(n));

  // 组合模板: [srcCount, prevCount, poolCount]
  const templates = [
    [4, 1, 0], [3, 2, 0], [3, 1, 1], [3, 0, 2],
    [2, 2, 1], [2, 1, 2], [2, 0, 3],
    [1, 2, 2], [1, 1, 3], [4, 0, 1], [5, 0, 0],
  ];

  const combos = [];
  const seen = new Set();

  for (const [sc, pc, qc] of templates) {
    // 对每种模板，尝试不同的src子集（通过偏移起始点）
    const srcVariations = Math.min(sc === 0 ? 1 : 3, Math.max(1, srcNums.length - sc + 1));
    for (let v = 0; v < srcVariations; v++) {
      const combo = [];
      const used = new Set();

      // 选src号码（带偏移）
      let picked = 0;
      for (let i = 0; i < srcNums.length && picked < sc; i++) {
        const idx = (v + i) % srcNums.length;
        if (!used.has(srcNums[idx])) { combo.push(srcNums[idx]); used.add(srcNums[idx]); picked++; }
      }
      // 选prev号码
      for (const n of prevNums) { if (combo.length >= sc + pc) break; if (!used.has(n)) { combo.push(n); used.add(n); } }
      // 选pool号码
      for (const n of poolTop) { if (combo.length >= 5) break; if (!used.has(n)) { combo.push(n); used.add(n); } }
      // 补全
      for (const s of scored) { if (combo.length >= 5) break; if (!used.has(s.n)) { combo.push(s.n); used.add(s.n); } }

      if (combo.length === 5) {
        const sorted = combo.sort((a, b) => a - b);
        const key = JSON.stringify(sorted);
        if (seen.has(key)) continue;
        seen.add(key);
        const comboScore = combo.reduce((sum, n) => sum + (poolMap.get(n) || 0), 0);
        combos.push({ numbers: sorted, score: comboScore, source: 'repeat' });
      }
    }
  }
  return combos.length > 0 ? combos : null;
}

// ═══ v10: 策略多样性 - 邻号偏重 ═══
// 策略: 邻号占主导(4个) + 选中行/前一期重号(1个)
function generateNeighborCombos(srcIdx, pool) {
  const src0 = srcIdx;
  if (src0 < 0 || src0 >= ALL_DRAWS.length) return null;
  const srcDraw = ALL_DRAWS[src0];
  if (!srcDraw) return null;
  const prevIdx = Math.max(0, src0 - 1);
  const prevDraw = ALL_DRAWS[prevIdx] || srcDraw;
  
  const srcSet = new Set(srcDraw.front);
  const prevSet = new Set(prevDraw.front);
  const nbSet = new Set();
  srcDraw.front.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });
  prevDraw.front.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });
  
  const poolMap = new Map(pool.map(e => [e.number, e.score || 0]));
  const scored = [];
  for (let n = 1; n <= 35; n++) {
    let s = 0;
    if (nbSet.has(n)) s += 15;
    if (srcSet.has(n)) s += 12;
    if (prevSet.has(n)) s += 10;
    if (s > 0) scored.push({ n, s: s + (poolMap.get(n) || 0) * 0.5 });
  }
  scored.sort((a, b) => b.s - a.s);
  
  // 分类号码
  const nbNums = scored.filter(s => nbSet.has(s.n) && !srcSet.has(s.n) && !prevSet.has(s.n)).map(s => s.n);
  const repNums = scored.filter(s => (srcSet.has(s.n) || prevSet.has(s.n)) && !nbSet.has(s.n)).map(s => s.n);
  const poolTop = [...pool].sort((a, b) => b.score - a.score).map(e => e.number).filter(n => !nbSet.has(n) && !srcSet.has(n) && !prevSet.has(n));

  // 组合模板: [nbCount, repCount, poolCount]
  const templates = [
    [4, 1, 0], [3, 2, 0], [3, 1, 1], [3, 0, 2],
    [2, 2, 1], [2, 1, 2], [2, 0, 3],
    [1, 2, 2], [1, 1, 3], [4, 0, 1], [5, 0, 0],
  ];

  const combos = [];
  const seen = new Set();

  for (const [nc, rc, qc] of templates) {
    const nbVariations = Math.min(nc === 0 ? 1 : 3, Math.max(1, nbNums.length - nc + 1));
    for (let v = 0; v < nbVariations; v++) {
      const combo = [];
      const used = new Set();

      let picked = 0;
      for (let i = 0; i < nbNums.length && picked < nc; i++) {
        const idx = (v + i) % nbNums.length;
        if (!used.has(nbNums[idx])) { combo.push(nbNums[idx]); used.add(nbNums[idx]); picked++; }
      }
      for (const n of repNums) { if (combo.length >= nc + rc) break; if (!used.has(n)) { combo.push(n); used.add(n); } }
      for (const n of poolTop) { if (combo.length >= 5) break; if (!used.has(n)) { combo.push(n); used.add(n); } }
      for (const s of scored) { if (combo.length >= 5) break; if (!used.has(s.n)) { combo.push(s.n); used.add(s.n); } }

      if (combo.length === 5) {
        const sorted = combo.sort((a, b) => a - b);
        const key = JSON.stringify(sorted);
        if (seen.has(key)) continue;
        seen.add(key);
        const comboScore = combo.reduce((sum, n) => sum + (poolMap.get(n) || 0), 0);
        combos.push({ numbers: sorted, score: comboScore, source: 'neighbor' });
      }
    }
  }
  return combos.length > 0 ? combos : null;
}

// ═══ v10: 策略多样性 - 桥接偏重 ═══
// 策略: 桥接号码(±1~5)占主导(3个) + 选中行(1个) + 前一期(1个)
function generateBridgeCombos(srcIdx, pool) {
  const src0 = srcIdx;
  if (src0 < 0 || src0 >= ALL_DRAWS.length) return null;
  const srcDraw = ALL_DRAWS[src0];
  if (!srcDraw) return null;
  const prevIdx = Math.max(0, src0 - 1);
  const prevDraw = ALL_DRAWS[prevIdx] || srcDraw;
  
  const srcSet = new Set(srcDraw.front);
  const prevSet = new Set(prevDraw.front);
  
  // 桥接: 选中行号码的±1~5
  const bridgeFreq = new Array(36).fill(0);
  srcDraw.front.forEach(n => {
    for (let d = 1; d <= 5; d++) {
      if (n - d >= 1) bridgeFreq[n - d]++;
      if (n + d <= 35) bridgeFreq[n + d]++;
    }
  });
  
  const poolMap = new Map(pool.map(e => [e.number, e.score || 0]));
  const scored = [];
  for (let n = 1; n <= 35; n++) {
    let s = bridgeFreq[n] * 10;
    if (srcSet.has(n)) s += 5;
    if (prevSet.has(n)) s += 8;
    if (s > 0) scored.push({ n, s: s + (poolMap.get(n) || 0) * 0.5 });
  }
  scored.sort((a, b) => b.s - a.s);
  
  // 分类号码
  const brNums = scored.filter(s => !srcSet.has(s.n) && !prevSet.has(s.n) && bridgeFreq[s.n] > 0).map(s => s.n);
  const repNums = scored.filter(s => (srcSet.has(s.n) || prevSet.has(s.n)) && bridgeFreq[s.n] === 0).map(s => s.n);
  const poolTop = [...pool].sort((a, b) => b.score - a.score).map(e => e.number).filter(n => !srcSet.has(n) && !prevSet.has(n) && bridgeFreq[n] === 0);

  // 组合模板: [brCount, repCount, poolCount]
  const templates = [
    [3, 1, 1], [3, 2, 0], [3, 0, 2], [4, 1, 0],
    [4, 0, 1], [2, 2, 1], [2, 1, 2], [2, 0, 3],
    [1, 2, 2], [1, 1, 3], [5, 0, 0],
  ];

  const combos = [];
  const seen = new Set();

  for (const [bc, rc, qc] of templates) {
    const brVariations = Math.min(bc === 0 ? 1 : 3, Math.max(1, brNums.length - bc + 1));
    for (let v = 0; v < brVariations; v++) {
      const combo = [];
      const used = new Set();

      let picked = 0;
      for (let i = 0; i < brNums.length && picked < bc; i++) {
        const idx = (v + i) % brNums.length;
        if (!used.has(brNums[idx])) { combo.push(brNums[idx]); used.add(brNums[idx]); picked++; }
      }
      for (const n of repNums) { if (combo.length >= bc + rc) break; if (!used.has(n)) { combo.push(n); used.add(n); } }
      // 也从src/prev中选（即使有桥接频率）
      for (const s of scored) { if (combo.length >= bc + rc) break; if (!used.has(s.n) && (srcSet.has(s.n) || prevSet.has(s.n))) { combo.push(s.n); used.add(s.n); } }
      for (const n of poolTop) { if (combo.length >= 5) break; if (!used.has(n)) { combo.push(n); used.add(n); } }
      for (const s of scored) { if (combo.length >= 5) break; if (!used.has(s.n)) { combo.push(s.n); used.add(s.n); } }

      if (combo.length === 5) {
        const sorted = combo.sort((a, b) => a - b);
        const key = JSON.stringify(sorted);
        if (seen.has(key)) continue;
        seen.add(key);
        const comboScore = combo.reduce((sum, n) => sum + (poolMap.get(n) || 0), 0);
        combos.push({ numbers: sorted, score: comboScore, source: 'bridge' });
      }
    }
  }
  return combos.length > 0 ? combos : null;
}

// ═══ v10: 策略多样性 - 等差偏重 ═══
// 策略: 等差延伸点(±1~4)占主导(3个) + 选中行(1个) + 邻号(1个)
function generateArithmeticCombos(srcIdx, pool) {
  const src0 = srcIdx;
  if (src0 < 0 || src0 >= ALL_DRAWS.length) return null;
  const srcDraw = ALL_DRAWS[src0];
  if (!srcDraw) return null;
  const prevIdx = Math.max(0, src0 - 1);
  const prevDraw = ALL_DRAWS[prevIdx] || srcDraw;
  
  const srcSet = new Set(srcDraw.front);
  const prevSet = new Set(prevDraw.front);
  const nbSet = new Set();
  srcDraw.front.forEach(n => { if (n > 1) nbSet.add(n - 1); if (n < 35) nbSet.add(n + 1); });
  
  // 等差延伸: 对选中行号码对计算延伸点
  const arithFreq = new Array(36).fill(0);
  const sorted = [...srcDraw.front].sort((a, b) => a - b);
  for (let i = 0; i < sorted.length; i++) {
    for (let j = i + 1; j < sorted.length; j++) {
      const d = sorted[j] - sorted[i];
      if (d >= 1 && d <= 4) {
        const ext = sorted[j] + d;
        if (ext >= 1 && ext <= 35) arithFreq[ext] += (5 - d) * 2;
        // 邻号
        if (ext - 1 >= 1) arithFreq[ext - 1] += (5 - d);
        if (ext + 1 <= 35) arithFreq[ext + 1] += (5 - d);
      }
    }
  }
  
  const poolMap = new Map(pool.map(e => [e.number, e.score || 0]));
  const scored = [];
  for (let n = 1; n <= 35; n++) {
    let s = arithFreq[n];
    if (srcSet.has(n)) s += 5;
    if (prevSet.has(n)) s += 8;
    if (nbSet.has(n)) s += 6;
    if (s > 0) scored.push({ n, s: s + (poolMap.get(n) || 0) * 0.5 });
  }
  scored.sort((a, b) => b.s - a.s);
  
  const combos = [];
  const seen = new Set();
  for (let t = 0; t < 20; t++) {
    const used = new Set();
    const combo = [];
    // 等差延伸(3个)
    for (let j = 0; j < scored.length && combo.length < 3; j++) {
      const idx = (t * 3 + j) % scored.length;
      if (!used.has(scored[idx].n) && arithFreq[scored[idx].n] > 0) {
        combo.push(scored[idx].n); used.add(scored[idx].n);
      }
    }
    for (const s of scored) { if (combo.length >= 3) break; if (!used.has(s.n) && arithFreq[s.n] > 0) { combo.push(s.n); used.add(s.n); } }
    // 加1个选中行
    for (const s of scored) { if (combo.length >= 4) break; if (!used.has(s.n) && srcSet.has(s.n)) { combo.push(s.n); used.add(s.n); } }
    // 加1个邻号
    for (const s of scored) { if (combo.length >= 5) break; if (!used.has(s.n) && nbSet.has(s.n)) { combo.push(s.n); used.add(s.n); } }
    // 补全
    for (const s of scored) { if (combo.length >= 5) break; if (!used.has(s.n)) { combo.push(s.n); used.add(s.n); } }
    if (combo.length === 5) {
      const sorted = combo.sort((a, b) => a - b);
      const key = JSON.stringify(sorted);
      if (seen.has(key)) continue;
      seen.add(key);
      const comboScore = combo.reduce((sum, n) => sum + (poolMap.get(n) || 0), 0);
      combos.push({ numbers: sorted, score: comboScore, source: 'arithmetic' });
    }
  }
  return combos.length > 0 ? combos : null;
}

// ===================== 预测主流程 =====================
function predict(sourceIssue, targetIssue, fastMode = false) {
  const sourceDraw = issueMap[sourceIssue];
  const targetDraw = issueMap[targetIssue];

  if (!sourceDraw) {
    console.error(`找不到选中行 ${sourceIssue}`);
    return null;
  }

  // 计算源数据的尾号
  const sourceTails = tails(sourceDraw.front);

  // 计算目标尾号和区间（如果有目标数据的话）
  const targetTails = targetDraw ? tails(targetDraw.front) : null;
  const targetIv = targetDraw ? intervalRatio(targetDraw.front) : null;

  // 获取相邻期数据用于极端检测
  const allIssues = ALL_DRAWS.map((d) => d.issue);
  const srcIdx = allIssues.indexOf(sourceIssue);
  
  // 前区评分改用前一期(srcIdx-1)作为锚点/桥梁/热号参考
  // 注意: srcIdx+9在升序数组中是未来数据(泄露!), 必须用srcIdx-1
  const _tpIdx = Math.max(0, srcIdx - 1);
  const _tpDraw = (_tpIdx < ALL_DRAWS.length && ALL_DRAWS[_tpIdx]) ? ALL_DRAWS[_tpIdx] : sourceDraw;
  const frontRefDraw = _tpDraw;
  
  const neighbors = [];
  for (let i = srcIdx - 1; i >= 0 && neighbors.length < 3; i--) {
    if (allIssues[i] !== targetIssue) {
      neighbors.push(issueMap[allIssues[i]]);
    }
  }

  const extremeFlags = detectExtreme(sourceDraw, neighbors);

  // 🆕 计算热号分布（改用目标行前一期作为参考）
  const hotness = computeHotness(Math.min(_tpIdx, ALL_DRAWS.length - 1), 10);

  // 🆕 S1: +10期趋势映射（间隔+13）
  const plusTenTrend = buildPlusTenTrendMap(srcIdx, 50, 13);

  // 🆕 S1b: +12期趋势映射（从source12视角，间隔+13）
  // source12 = target - 12 = srcIdx + 10 - 12 = srcIdx - 2
  const src12Idx = srcIdx - 2;
  const plus12Trend = src12Idx >= 0 ? buildPlusTenTrendMap(src12Idx, 50, 13) : { targetMap: new Map(), neighborMap: new Map() };

  // 🆕 S2: 桥梁分析（改用目标行前一期作为锚点）
  const bridgeMap = buildBridgeMap(frontRefDraw.front, frontRefDraw.front);

  // 🆕 S3: 等距端点分析（改用目标行前一期作为锚点）
  const arithmeticMap = buildArithmeticEndpointMap(frontRefDraw.front, frontRefDraw.front, 6);

  // 🆕 S5: 参考行
  const referenceRows = buildReferenceWindow(srcIdx, 6);
  // 🆕 加一行：目标期前一期作为额外参考行（结构相似，Union +2.4pp，全5球翻倍）
  {
    const tIdx = allIssues.indexOf(targetIssue);
    const idx = tIdx - 1;
    if (idx > srcIdx && idx < ALL_DRAWS.length) {
      const d = ALL_DRAWS[idx];
      if (d && !referenceRows.some(r => r.row === idx)) {
        const pn = [...d.front].sort((a, b) => a - b);
        const { pairs: xp, longestRun: xlr } = countConsecutivePairs(pn);
        const xs = buildConsecutiveSegments(pn);
        const xae = new Set();
        for (let dd = 2; dd <= 6; dd++) {
          pn.forEach((n) => {
            const a = n - dd, b = n + dd;
            if (a >= 1 && a <= 35 && pn.includes(a)) { xae.add(n); xae.add(a); }
            if (b >= 1 && b <= 35 && pn.includes(b)) { xae.add(n); xae.add(b); }
          });
        }
        const xbg = new Set(), xbe = new Set();
        for (let j = 0; j < pn.length - 1; j++) {
          const g = pn[j + 1] - pn[j];
          if (g >= 2 && g <= 4) {
            for (let m = pn[j] + 1; m < pn[j + 1]; m++) xbg.add(m);
            xbe.add(pn[j]); xbe.add(pn[j + 1]);
          }
        }
        const xtc = new Map();
        pn.forEach((n) => xtc.set(n % 10, (xtc.get(n % 10) || 0) + 1));
        let xst = null, xsc = 0;
        xtc.forEach((c, t) => { if (c > xsc) { xsc = c; xst = t; } });
        referenceRows.push({
          row: idx,
          numbers: pn, numberSet: new Set(pn),
          tailSet: new Set(pn.map((n) => n % 10)),
          ivKey: intervalRatio(pn).join(":"), iv: intervalRatio(pn),
          consecutivePairs: xp, longestRun: xlr, consecutiveSegments: xs,
          arithEndpoints: xae, bridgeGaps: xbg, bridgeEndpoints: xbe,
          strongestTail: xst, strongestCount: xsc,
        });
      }
    }
  }

  // 🆕 尾号转移分析（lookback增大到50，确保有足够数据统计10期间隔的转移）
  const tailTransData = analyzeTailTransitions(srcIdx, 50);
  
  // 获取前一期的尾号（修复泄露：srcIdx+9是未来数据，改为srcIdx-1）
  const targetPrevIdx = Math.max(0, srcIdx - 1);
  const targetPrevDraw = ALL_DRAWS[targetPrevIdx] || null;
  const prevDrawTails = targetPrevDraw ? tails(targetPrevDraw.front) : [];
  
  // 🆕 传入prevDrawTails，利用连续期尾号重叠规律
  const predictedTails = predictLikelyTails(sourceTails, tailTransData, prevDrawTails);

  // 🆕 v5: 区间比预测（基于历史转移+时效加权）
  const sourceIv = intervalRatio(sourceDraw.front);
  const ivPrediction = predictTargetIntervalRatio(srcIdx, sourceIv);

  // 🆕 v11: 计算跨源关系组合加分（按实际命中率加权的交集评分）
  const comboRelationBonus = computeComboRelationBonus(sourceDraw, frontRefDraw, srcIdx);

  // 组装额外映射
  const extraMaps = {
    plusTenTargetMap: plusTenTrend.targetMap,
    plusTenNeighborMap: plusTenTrend.neighborMap,
    plus12TargetMap: plus12Trend.targetMap,      // 🆕 +12期趋势信号
    plus12NeighborMap: plus12Trend.neighborMap,  // 🆕 +12期趋势信号
    bridgeGapMap: bridgeMap.gapMap,
    bridgeEndpointMap: bridgeMap.endpointMap,
    arithmeticEndpointMap: arithmeticMap,
    prevDrawTails,
    srcIdx, // 传递源行索引，用于尾号遗漏和连续出现分析
    comboRelationBonus, // 🆕 v10: 跨源关系组合加分
  };

  // 生成号码池（改用目标行前一期作为锚点参考）
  const pool = generateCandidatePool(frontRefDraw, targetTails, targetIv, extremeFlags, hotness, extraMaps, ivPrediction, targetDraw, predictedTails);

  // 生成组合（v8: 改用目标行前一期作为锚点和和值参考）
  const sourceSum = frontRefDraw.front.reduce((a, b) => a + b, 0);
  const _origCombinations = fastMode
    ? generateCombinationsFast(pool, CONFIG.pickCount, sourceTails, predictedTails, referenceRows, frontRefDraw.front, frontRefDraw.front, ivPrediction, sourceSum)
    : generateCombinations(pool, CONFIG.pickCount);

  // 智能5策略独立模式（v10.1: 单注命中率50%，比基线+6.80pp）
  const _smart5Nums = smart5Strategy(srcIdx, pool);
  const _smart5Combo = { numbers: _smart5Nums, source: '智能5策略' };
  
  // 组合：关系组合策略5注不同策略（v10.6: 跨源信号已融入策略4-6）
  const _relationshipCombos = generate5DifferentStrategyCombos(srcIdx, pool, comboRelationBonus);

  // ═══ v12: 策略组合直接使用（天然多样性最优） ═══
  let combinations = _relationshipCombos.length >= 5
    ? _relationshipCombos.slice(0, 5)
    : [_smart5Combo, ..._origCombinations.slice(0, 4)];

  // ===== 补漏6生成（补盲区策略） =====
  const _top5Covered = new Set();
  combinations.slice(0, 5).forEach(c => c.numbers.forEach(n => _top5Covered.add(n)));
  const _top5Freq = new Map();
  combinations.slice(0, 5).forEach(c => c.numbers.forEach(n => _top5Freq.set(n, (_top5Freq.get(n) || 0) + 1)));

  // 计算遗漏/热号（改用目标行前一期作为参考）
  const _missMap = new Map(), _hotMap = new Map();
  const _tpIdxSafe = Math.min(_tpIdx, ALL_DRAWS.length - 1);
  for (let n = 1; n <= 35; n++) {
    let m = 0, h = 0;
    for (let i = _tpIdxSafe - 1; i >= Math.max(0, _tpIdxSafe - 20); i--) { if (ALL_DRAWS[i].front.includes(n)) break; m++; }
    for (let i = _tpIdxSafe - 1; i >= Math.max(0, _tpIdxSafe - 10); i--) { if (ALL_DRAWS[i].front.includes(n)) h++; }
    _missMap.set(n, m); _hotMap.set(n, h);
  }
  // 区间平衡
  const _top5Iv = [0, 0, 0];
  combinations.slice(0, 5).forEach(c => c.numbers.forEach(n => { if (n <= 12) _top5Iv[0]++; else if (n <= 24) _top5Iv[1]++; else _top5Iv[2]++; }));
  const _ivMin = _top5Iv.indexOf(Math.min(..._top5Iv));
  const _predTails = predictedTails ? new Set(predictedTails.slice(0, 5).map(([t]) => t)) : new Set();

  // 核心：只选Top5未覆盖的池号码
  // 🆕 v9: 补漏6也融入热冷号评分(回测: 补漏6>=2从11.1%提升到13.1%)
  const _hcFreq = new Array(36).fill(0);
  const _hcWindowNums = [];
  for (let i = srcIdx; i <= srcIdx + 4 && i < ALL_DRAWS.length; i++)
    ALL_DRAWS[i].front.forEach(n => { _hcFreq[n]++; _hcWindowNums.push(n); });
  const _hcHotSet = new Set();
  const _hcColdNbSet = new Set();
  const _hcNbSet = new Set();
  ALL_DRAWS[srcIdx].front.forEach(n => { if(n>1)_hcNbSet.add(n-1); if(n<35)_hcNbSet.add(n+1); });
  const _hcPrev = (srcIdx - 1 >= 0) ? ALL_DRAWS[srcIdx - 1] : ALL_DRAWS[srcIdx];
  _hcPrev.front.forEach(n => { if(n>1)_hcNbSet.add(n-1); if(n<35)_hcNbSet.add(n+1); });
  for (let n = 1; n <= 35; n++) {
    if (_hcFreq[n] >= 2) _hcHotSet.add(n);
    else if (_hcFreq[n] === 0 && _hcNbSet.has(n)) _hcColdNbSet.add(n);
  }
  // 🆕 v9.2: 补漏6桥接号码集合
  const _hcBridgeNums = getBridgeNums(_hcWindowNums, ALL_DRAWS[srcIdx].front);
  const _hcBridgeSet = new Set(_hcBridgeNums.filter(n => _hcNbSet.has(n)));

  const _c6Scored = pool
    .filter(e => !_top5Covered.has(e.number))
    .map(e => {
      const n = e.number, miss = _missMap.get(n) || 0, hot = _hotMap.get(n) || 0;
      let s = e.score;
      if (_predTails.has(n % 10)) s += 10;
      const zone = n <= 12 ? 0 : n <= 24 ? 1 : 2;
      if (zone === _ivMin) s += 6;
      if (hot >= 3) s += 8; else if (hot >= 2) s += 4;
      if (miss >= 10) s += 5; else if (miss >= 7) s += 3;
      s += 25; // 补盲区核心加分
      // 🆕 v9: 热冷号加分
      if (_hcHotSet.has(n)) s += 5;
      if (_hcColdNbSet.has(n)) s += 5;
      // 🆕 v9.2: 桥接号码加分（补漏6中桥接号=冷号但原筛选未捕获）
      if (_hcBridgeSet.has(n)) s += 3;
      let md = Infinity; _top5Covered.forEach(cn => { const d = Math.abs(n - cn); if (d < md) md = d; });
      if (md === 1) s += 12; else if (md === 2) s += 6; else if (md === 3) s += 3;
      return { number: n, score6: s };
    })
    .sort((a, b) => b.score6 - a.score6);

  let bulou6 = null;
  if (_c6Scored.length >= 5) {
    bulou6 = _c6Scored.slice(0, 5).map(e => e.number).sort((a, b) => a - b);
  } else if (_c6Scored.length > 0) {
    // 已覆盖池号码补充（5折评分）
    const _supp = pool
      .filter(e => _top5Covered.has(e.number) && !_c6Scored.some(c => c.number === e.number))
      .map(e => ({ number: e.number, score6: e.score * 0.5 }))
      .sort((a, b) => b.score6 - a.score6);
    
    let _all = [..._c6Scored, ..._supp].slice(0, 5);
    bulou6 = _all.map(e => e.number).sort((a, b) => a - b);
  }

  return {
    sourceIssue,
    targetIssue,
    sourceFront: sourceDraw.front,
    targetFront: targetDraw ? targetDraw.front : null,
    targetTails: targetTails || sourceTails,
    extremeFlags,
    pool,
    combinations,
    predictedTails,
    ivPrediction,
    bulou6,  // 🆕 补漏6号码（补盲区策略）
  };
}

// ===================== 构建配对 =====================
function buildPairs(interval) {
  const pairs = [];
  const sortedIssues = ALL_DRAWS.map((d) => d.issue).sort();
  sortedIssues.forEach((srcIssue) => {
    const srcNum = parseInt(srcIssue.slice(4));
    const tgtIssue = srcIssue.slice(0, 4) + String(srcNum + interval).padStart(3, "0");
    if (issueMap[tgtIssue]) {
      pairs.push([srcIssue, tgtIssue]);
    }
  });
  return pairs;
}

// ===================== 后区预测 (采用 predict_unified.py 逻辑: 桥接池+和值/差值常量+联合转移) =====================

// 后区转移表 TOP3 (与 predict_unified.py 一致, 全历史统计)
const BACK_TRANSFER = {1:[1,2,8],2:[2,8,12],3:[11,1,10],4:[5,4,10],5:[5,1,8],
                       6:[10,8,6],7:[8,1,5],8:[12,8,4],9:[6,2,10],10:[10,4,2],
                       11:[11,1,10],12:[2,12,5]};

// 后区组合常量 (与间隔无关, 全历史统计)
const BACK_SUM_PREF  = {13:6, 14:5, 9:4, 15:3, 16:3, 6:2, 12:2, 10:2, 11:2};
const BACK_DIFF_PREF = {1:6, 4:5, 6:4, 3:4, 5:3, 2:2};

// 构建后区联合转移表 (上期(a,b) -> 下期(x,y))
function buildBackJointTrans(srcIdx) {
  const jointCount = {};
  for (let i = 0; i < srcIdx; i++) {
    const cur = ALL_DRAWS[i], nxt = ALL_DRAWS[i + 1];
    if (!cur || !cur.back || !nxt || !nxt.back) continue;
    const prev = [...cur.back].sort((a, b) => a - b).join(',');
    const next = [...nxt.back].sort((a, b) => a - b).join(',');
    if (!jointCount[prev]) jointCount[prev] = {};
    jointCount[prev][next] = (jointCount[prev][next] || 0) + 1;
  }
  return jointCount;
}

function predictBack(sourceDrawIdx) {
  // 取目标行前一期的后区号 (sourceDrawIdx + 9)，无数据时回退到 sourceDrawIdx
  let prevDraw = ALL_DRAWS[sourceDrawIdx + 9];
  if (!prevDraw || !prevDraw.back) prevDraw = ALL_DRAWS[sourceDrawIdx];
  if (!prevDraw || !prevDraw.back) return { top6: [], combos: [], layer: {}, ranked: [] };

  const [a, b] = prevDraw.back;
  const layer = {};

  // ① 桥接池: p±1~5 (平权 +1), p±1 相邻, p 重复, 转移表 TOP3 (与 predict_unified.py 一致)
  const add = (x) => { if (x >= 1 && x <= 12) layer[x] = (layer[x] || 0) + 1; };
  for (const p of [a, b]) {
    for (let d = 1; d <= 5; d++) { add(p + d); add(p - d); }
    add(p - 1); add(p + 1); add(p);
    for (const t of (BACK_TRANSFER[p] || [])) add(t);
  }

  const pool = Object.keys(layer).map(Number);
  const strong = pool.filter(x => layer[x] >= 2);
  const cand = strong.length >= 2 ? strong : pool;

  // ② 联合转移统计
  const jointCount = buildBackJointTrans(sourceDrawIdx);
  const prevk = [...prevDraw.back].sort((x, y) => x - y).join(',');

  // ③ 组合打分: SUM_PREF + DIFF_PREF + joint * 2.0, 硬过滤 和值10~20 差值3~7
  const combos = [];
  for (let ii = 0; ii < cand.length; ii++) {
    for (let jj = ii + 1; jj < cand.length; jj++) {
      const x = cand[ii], y = cand[jj];
      const sm = x + y, df = Math.abs(x - y);
      if (sm < 10 || sm > 20 || df < 3 || df > 7) continue;
      const ck = x < y ? x + ',' + y : y + ',' + x;
      const j = (jointCount[prevk] && jointCount[prevk][ck]) || 0;
      const constScore = (BACK_SUM_PREF[sm] || 0) + (BACK_DIFF_PREF[df] || 0);
      const fin = constScore + j * 2.0;
      combos.push({ score: fin, numbers: [Math.min(x, y), Math.max(x, y)], sum: sm, diff: df });
    }
  }
  combos.sort((p, q) => q.score - p.score);

  // 号码排名 (按 layer 票数)
  const ranked = pool.sort((x, y) => (layer[y] || 0) - (layer[x] || 0));
  const top6 = ranked.slice(0, 6);

  return { top6, combos, layer, ranked };
}

